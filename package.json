{
  "name": "petrichor",
  "version": "0.1.0",
  "description": "Repository-local structural indexing and symbol lookup for coding agents.",
  "main": "dist/cli.js",
  "bin": {
    "petrichor": "dist/cli.js"
  },
  "scripts": {
